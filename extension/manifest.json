{
  "manifest_version": 3,
  "name": "UniStyle",
  "short_name": "UniStyle",
  "version": "1.7.2",
  "description": "Unicode text formatter - 20+ styles (bold, italic, script) for Discord, Notion, Twitter, Slack. Free, no signup.",
  "homepage_url": "https://unistyle.io",
  "action": {
    "default_popup": "popup.html",
    "default_title": "UniStyle",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["contextMenus", "activeTab", "scripting", "storage", "clipboardWrite"],
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["panel.css"],
      "matches": ["<all_urls>"]
    }
  ],
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      },
      "description": "Open the UniStyle popup"
    },
    "transform-inline": {
      "suggested_key": {
        "default": "Ctrl+Shift+U",
        "mac": "Command+Shift+U"
      },
      "description": "Transform selected text in place using your last-used style"
    },
    "open-panel-inline": {
      "suggested_key": {
        "default": "Ctrl+Shift+F",
        "mac": "Command+Shift+F"
      },
      "description": "Open the UniStyle panel for the currently selected text"
    }
  }
}
